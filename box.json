{
  "main": "bin/ngramx",
  "output": "ngramx.phar",
  "directories": [
    "src",
    "templates"
  ],
  "files": [
    "composer.json",
    "LICENSE"
  ],
  "finder": [
    {
      "name": "*.php",
      "exclude": [
        "tests",
        "Tests",
        "test",
        "Test"
      ],
      "in": "vendor"
    },
    {
      "name": "completion.*",
      "in": "vendor/symfony/console/Resources"
    }
  ],
  "compression": "GZ",
  "compactors": [
    "KevinGH\\Box\\Compactor\\Php"
  ],
  "stub": true,
  "banner": [
    "Ngramx CLI - Docker Development Environment Orchestration",
    "",
    "This file is part of Ngramx CLI.",
    "",
    "@link https://github.com/ngramx/ngramx"
  ]
}

