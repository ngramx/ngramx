{
    "name": "ngramx/cli",
    "description": "A CLI tool for orchestrating Docker-based development environments",
    "type": "project",
    "license": "Apache-2.0",
    "autoload": {
        "psr-4": {
            "Ngramx\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ngramx\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "symfony/console": "^7.0",
        "symfony/process": "^7.0",
        "symfony/yaml": "^7.0",
        "symfony/dotenv": "^7.4",
        "guzzlehttp/guzzle": "^7.10"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.40",
        "mockery/mockery": "^1.6",
        "humbug/box": "^4.6"
    },
    "bin": ["bin/ngramx"],
    "config": {
        "platform": {
            "php": "8.2"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/phpunit",
        "phpstan": "vendor/bin/phpstan analyse src tests --level=8",
        "cs-fix": "vendor/bin/php-cs-fixer fix"
    }
}
